        raise SRW.program_abort;
end;]]>
      </textSource>
    </function>
    <function name="cf_titreporteformula" returnType="character">
      <textSource>
      <![CDATA[function CF_TitReporteFormula return VARCHAR2 is
   vTitReporte varchar2(80);
   vTexto      varchar2(80);

begin
   select titulo || ' Cliente: ' || :p_cod_cliente || ' ' || F_RET_NOM_CLIENTE(:p_cod_cliente)
   into   vTitReporte
   from   titulos_reportes
   where  nom_reporte = :pg_NOM_REPORTE
     and  cod_idioma  = :pg_COD_IDIOMA;

   return vTitReporte;

exception

   when SRW.NO_DATA_FOUND then
       
      select texto
      into   vTexto
      from   mensajes_sistema
      where  num_mensaje  = '000047'
        and  cod_sistema  = 'PA'
        and  cod_idioma   = :pg_COD_IDIOMA;

        SRW.message(0, 'PA-000047 ' || vTexto);
        raise SRW.program_abort;
  
end;]]>
      </textSource>
    </function>
    <function name="cf_tipocambioformula" returnType="number">
      <textSource>
      <![CDATA[function CF_TipocambioFormula return Number is
   v_tipcamb number(16,2);
   v_mensaje varchar2(100);
begin
    begin
		    Cg_Utl.Obtiene_TC_Conta(1, :sysdate, v_tipcamb, v_mensaje);
    exception
        when others then
          v_tipcamb := null;
    end;
    return v_tipcamb;
end;]]>
      </textSource>
    </function>
