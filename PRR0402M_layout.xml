    <function name="cf_titempresaformula" returnType="character">
      <textSource>
      <![CDATA[function CF_TITEMPRESAFormula return VARCHAR2 is

   vTitEmpresa varchar2(80);
   vTexto      varchar2(80);

begin
   select tit_reportes 
   into   vTitEmpresa
   from   empresa
   where  cod_empresa = :pg_cOD_EMPRESA;

   return  upper(vTitEmpresa);
exception

   when SRW.NO_DATA_FOUND then
       
      select texto
      into   vTexto
      from   mensajes_sistema
      where  num_mensaje  = '000046'
        and  cod_sistema  = 'PA'
        and  cod_idioma   = :pg_coD_IDIOMA;

        SRW.message(0, 'PA-000046 ' || vTexto);
        raise SRW.program_abort;

end;]]>
      </textSource>
    </function>
    <function name="cf_titsistemaformula" returnType="character">
      <textSource>
      <![CDATA[function CF_TitSistemaFormula return VARCHAR2 is
   vTitSistema varchar2(80);
   vTexto      varchar2(80);
begin
   select  titulo
   into    vTitSistema
   from    titulos_sistemas
   where   cod_sistema = :pg_COD_SISTEMA
     and   cod_idioma  = :pg_COD_IDIOMA;

   return upper(vTitSistema);

exception

   when SRW.NO_DATA_FOUND then
       
      select texto
      into   vTexto
      from   mensajes_sistema
      where  num_mensaje  = '000048'
        and  cod_sistema  = 'PA'
        and  cod_idioma   = :pg_COD_IDIOMA;

        SRW.message(0, 'PA-000048 ' || vTexto);
        raise SRW.program_abort;

end;]]>
      </textSource>
    </function>
    <function name="cf_titagenciaformula" returnType="character">
      <textSource>
      <![CDATA[function CF_TitAgenciaFormula return VARCHAR2 is

   vTitAgencia varchar2(80);
   vTexto      varchar2(80);

begin

   select descripcion
   into   vTitAgencia
   from   agencia
   where  cod_empresa = :pg_COD_EMPRESA
     and  cod_agencia = :pg_COD_AGENCIA;

   return upper(vTitAgencia); 

exception

   when SRW.NO_DATA_FOUND then
       
      select texto
      into   vTexto
      from   mensajes_sistema
      where  num_mensaje  = '000045'
        and  cod_sistema  = 'PA'
        and  cod_idioma   = :pg_COD_IDIOMA;

